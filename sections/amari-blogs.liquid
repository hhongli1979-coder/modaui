<div class="bg-white py-16 lg:py-24">
  <div class="container mx-auto px-4">
    {% if section.settings.heading != blank %}
      <h2 class="text-3xl lg:text-4xl font-bold text-center text-gray-900 mb-12">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {% if section.settings.blog != blank %}
        {% for article in section.settings.blog.articles limit: section.settings.articles_to_show %}
          <article class="group">
            <a href="{{ article.url }}" class="block">
              {%- comment -%} Article Image {%- endcomment -%}
              <div class="relative rounded-2xl overflow-hidden mb-5 aspect-[4/3]">
                {% if article.image %}
                  {{ article.image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover group-hover:scale-110 transition-transform duration-500', loading: 'lazy' }}
                {% else %}
                  <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                    <span class="text-gray-400">No image</span>
                  </div>
                {% endif %}

                {%- comment -%} Date Badge {%- endcomment -%}
                <div class="absolute bottom-4 left-4 bg-white px-4 py-2 rounded-lg shadow-md">
                  <time class="text-sm font-medium text-gray-900">
                    {{ article.published_at | date: "%d %B, %Y" }}
                  </time>
                </div>
              </div>

              {%- comment -%} Article Content {%- endcomment -%}
              <div class="space-y-3">
                <h3 class="text-xl font-bold text-gray-900 group-hover:text-amber-700 transition-colors line-clamp-2">
                  {{ article.title }}
                </h3>

                {% if article.excerpt != blank %}
                  <p class="text-gray-600 line-clamp-3">
                    {{ article.excerpt | strip_html }}
                  </p>
                {% elsif article.content != blank %}
                  <p class="text-gray-600 line-clamp-3">
                    {{ article.content | strip_html | truncate: 150 }}
                  </p>
                {% endif %}

                <div class="flex items-center gap-2 text-amber-700 font-medium">
                  Read More
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="w-4 h-4">
                    <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            </a>
          </article>
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.show_view_all and section.settings.blog != blank %}
      <div class="text-center mt-12">
        <a href="{{ section.settings.blog.url }}" class="inline-flex items-center gap-2 bg-amber-800 hover:bg-amber-900 text-white px-8 py-3 rounded-md font-medium transition-colors duration-200">
          View All
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="w-4 h-4">
            <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Amari Blogs",
  "tag": "section",
  "class": "section-blogs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "News & Blogs"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Articles to Show",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' Button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Amari Blogs"
    }
  ]
}
{% endschema %}
