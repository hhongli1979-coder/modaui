<div class="bg-white py-16 lg:py-24">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-6 max-w-7xl mx-auto">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'banner' %}
            <div class="relative rounded-3xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300 {{ block.settings.height_class }}">
              {%- comment -%} Background Image {%- endcomment -%}
              {% if block.settings.image != blank %}
                <div class="absolute inset-0">
                  {{ block.settings.image | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
                  <div class="absolute inset-0 bg-gradient-to-r {{ block.settings.overlay_gradient }}"></div>
                </div>
              {% else %}
                <div class="absolute inset-0 {{ block.settings.bg_color }}"></div>
              {% endif %}

              {%- comment -%} Content {%- endcomment -%}
              <div class="relative z-10 p-8 lg:p-12 h-full flex flex-col justify-center {{ block.settings.text_align }}">
                {% if block.settings.discount_badge != blank %}
                  <div class="mb-4">
                    <span class="inline-block text-4xl lg:text-5xl font-bold {{ block.settings.text_color }}">
                      {{ block.settings.discount_badge }}
                    </span>
                  </div>
                {% endif %}

                {% if block.settings.heading != blank %}
                  <h3 class="text-2xl lg:text-3xl font-bold mb-3 {{ block.settings.text_color }}">
                    {{ block.settings.heading }}
                  </h3>
                {% endif %}

                {% if block.settings.subheading != blank %}
                  <p class="text-base lg:text-lg mb-6 {{ block.settings.text_color }} opacity-90">
                    {{ block.settings.subheading }}
                  </p>
                {% endif %}

                {% if block.settings.button_label != blank %}
                  <div>
                    <a href="{{ block.settings.button_link }}" class="inline-flex items-center gap-2 bg-amber-800 hover:bg-amber-900 text-white px-6 py-3 rounded-md font-medium transition-colors duration-200">
                      {{ block.settings.button_label }}
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="w-4 h-4">
                        <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Amari Promo Banners",
  "tag": "section",
  "class": "section-promo-banners",
  "settings": [],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "select",
          "id": "height_class",
          "label": "Banner Height",
          "options": [
            {
              "value": "min-h-[300px]",
              "label": "Small"
            },
            {
              "value": "min-h-[400px]",
              "label": "Medium"
            },
            {
              "value": "min-h-[500px]",
              "label": "Large"
            }
          ],
          "default": "min-h-[400px]"
        },
        {
          "type": "select",
          "id": "bg_color",
          "label": "Background Color (if no image)",
          "options": [
            {
              "value": "bg-amber-100",
              "label": "Light Amber"
            },
            {
              "value": "bg-amber-700",
              "label": "Dark Amber"
            },
            {
              "value": "bg-gray-100",
              "label": "Light Gray"
            },
            {
              "value": "bg-pink-100",
              "label": "Light Pink"
            }
          ],
          "default": "bg-amber-100"
        },
        {
          "type": "select",
          "id": "overlay_gradient",
          "label": "Image Overlay",
          "options": [
            {
              "value": "from-black/50 to-transparent",
              "label": "Dark Left"
            },
            {
              "value": "from-transparent to-black/50",
              "label": "Dark Right"
            },
            {
              "value": "from-black/30 to-black/30",
              "label": "Dark Overall"
            },
            {
              "value": "from-transparent to-transparent",
              "label": "None"
            }
          ],
          "default": "from-black/30 to-black/30"
        },
        {
          "type": "text",
          "id": "discount_badge",
          "label": "Discount Badge (e.g., '30% Off')"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Text Alignment",
          "options": [
            {
              "value": "text-left",
              "label": "Left"
            },
            {
              "value": "text-center",
              "label": "Center"
            },
            {
              "value": "text-right",
              "label": "Right"
            }
          ],
          "default": "text-left"
        },
        {
          "type": "select",
          "id": "text_color",
          "label": "Text Color",
          "options": [
            {
              "value": "text-white",
              "label": "White"
            },
            {
              "value": "text-gray-900",
              "label": "Dark"
            },
            {
              "value": "text-amber-900",
              "label": "Amber"
            }
          ],
          "default": "text-gray-900"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Amari Promo Banners",
      "blocks": [
        {
          "type": "banner",
          "settings": {
            "discount_badge": "30% Off",
            "heading": "Complete Care. One Combo.",
            "subheading": "Ultimate skin care set for glowing skin",
            "button_label": "Shop Combo",
            "text_color": "text-gray-900"
          }
        },
        {
          "type": "banner",
          "settings": {
            "discount_badge": "10% Off",
            "heading": "Limited Time Offer!",
            "subheading": "Pore Minimizer Perfection Cleanser",
            "button_label": "Shop Now",
            "text_color": "text-gray-900"
          }
        },
        {
          "type": "banner",
          "settings": {
            "discount_badge": "25% Off",
            "heading": "Turn Back Time with Every Drop!",
            "subheading": "Youthful Glow Anti-Aging Serum",
            "button_label": "Shop Now",
            "text_color": "text-white"
          }
        },
        {
          "type": "banner",
          "settings": {
            "heading": "Radiance Unveiled",
            "subheading": "Skin Whitening/Brightening Cream",
            "button_label": "Shop Now",
            "text_color": "text-gray-900"
          }
        }
      ]
    }
  ]
}
{% endschema %}
