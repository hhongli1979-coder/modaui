<div class="bg-gradient-to-br from-amber-50 to-orange-50 py-16 lg:py-24">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center max-w-7xl mx-auto">
      {%- comment -%} Content Section {%- endcomment -%}
      <div class="space-y-8 order-2 lg:order-1">
        {% if section.settings.heading != blank %}
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 leading-tight">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <p class="text-gray-600 leading-relaxed">
            {{ section.settings.description }}
          </p>
        {% endif %}

        {%- comment -%} Stats {%- endcomment -%}
        <div class="grid grid-cols-3 gap-8">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'stat' %}
                <div class="text-center">
                  {% if block.settings.number != blank %}
                    <div class="text-4xl lg:text-5xl font-bold text-amber-700 mb-2">
                      {{ block.settings.number }}
                    </div>
                  {% endif %}
                  {% if block.settings.label != blank %}
                    <p class="text-sm text-gray-600">
                      {{ block.settings.label }}
                    </p>
                  {% endif %}
                </div>
            {% endcase %}
          {% endfor %}
        </div>

        {% if section.settings.button_label != blank %}
          <div>
            <a href="{{ section.settings.button_link }}" class="inline-flex items-center gap-2 bg-amber-800 hover:bg-amber-900 text-white px-8 py-3 rounded-md font-medium transition-colors duration-200">
              {{ section.settings.button_label }}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="w-4 h-4">
                <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        {% endif %}
      </div>

      {%- comment -%} Images Grid Section {%- endcomment -%}
      <div class="grid grid-cols-2 gap-4 order-1 lg:order-2">
        {% if section.settings.image_1 != blank %}
          <div class="rounded-3xl overflow-hidden shadow-lg aspect-square">
            {{ section.settings.image_1 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
          </div>
        {% endif %}

        {% if section.settings.image_2 != blank %}
          <div class="rounded-3xl overflow-hidden shadow-lg aspect-square mt-12">
            {{ section.settings.image_2 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
          </div>
        {% endif %}

        {% if section.settings.image_3 != blank %}
          <div class="rounded-3xl overflow-hidden shadow-lg aspect-[3/4] col-span-2">
            {{ section.settings.image_3 | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Amari Expertise",
  "tag": "section",
  "class": "section-expertise",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Unlock Your True Beauty with Our Expertise"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "At Amari, we believe in the transformative power of skincare. Our journey began with a vision to redefine beauty by crafting products that go beyond the surface, nurturing your skin at its core."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Read More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 (Top Left)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (Top Right)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 (Bottom)"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number (e.g., 8K+)",
          "default": "8K+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Global Customers"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Amari Expertise",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "number": "8K+",
            "label": "Global Customers"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "12K+",
            "label": "Products Delivered"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "10+",
            "label": "Years In Business"
          }
        }
      ]
    }
  ]
}
{% endschema %}
