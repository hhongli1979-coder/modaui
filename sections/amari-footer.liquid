<footer class="bg-[#4A2C2A] text-white">
  {%- comment -%} Main Footer Content {%- endcomment -%}
  <div class="container mx-auto px-4 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      {%- comment -%} Brand Section {%- endcomment -%}
      <div class="lg:col-span-1">
        {% if section.settings.logo != blank %}
          <a href="/" class="inline-block mb-4">
            {{ section.settings.logo | image_url: width: 150 | image_tag: class: 'h-8 w-auto', loading: 'lazy' }}
          </a>
        {% elsif shop.name %}
          <a href="/" class="inline-block text-2xl font-bold mb-4">
            {{ shop.name }}
          </a>
        {% endif %}

        {% if section.settings.description != blank %}
          <p class="text-gray-300 text-sm leading-relaxed">
            {{ section.settings.description }}
          </p>
        {% endif %}
      </div>

      {%- comment -%} Footer Blocks {%- endcomment -%}
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'link_list' %}
            <div>
              {% if block.settings.heading != blank %}
                <h3 class="font-bold text-white mb-4">
                  {{ block.settings.heading }}
                </h3>
              {% endif %}

              {% if block.settings.menu != blank %}
                <ul class="space-y-2">
                  {% for link in block.settings.menu.links %}
                    <li>
                      <a href="{{ link.url }}" class="text-gray-300 hover:text-white transition-colors text-sm">
                        {{ link.title }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>

          {% when 'contact_info' %}
            <div>
              {% if block.settings.heading != blank %}
                <h3 class="font-bold text-white mb-4">
                  {{ block.settings.heading }}
                </h3>
              {% endif %}

              <div class="space-y-4">
                {% if block.settings.address != blank %}
                  <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <p class="text-gray-300 text-sm">
                      {{ block.settings.address }}
                    </p>
                  </div>
                {% endif %}

                {% if block.settings.email != blank %}
                  <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    <a href="mailto:{{ block.settings.email }}" class="text-gray-300 hover:text-white transition-colors text-sm">
                      {{ block.settings.email }}
                    </a>
                  </div>
                {% endif %}

                {% if block.settings.phone != blank %}
                  <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    <a href="tel:{{ block.settings.phone }}" class="text-gray-300 hover:text-white transition-colors text-sm">
                      {{ block.settings.phone }}
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>

  {%- comment -%} Footer Bottom {%- endcomment -%}
  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 py-6">
      <div class="flex flex-col lg:flex-row justify-between items-center gap-6">
        {%- comment -%} Copyright {%- endcomment -%}
        <div class="text-center lg:text-left">
          <p class="text-gray-400 text-sm">
            Copyright ©
            <a href="/" class="hover:text-white transition-colors">{{ shop.name }}</a>
            {{ 'now' | date: '%Y' }}, All rights reserved
          </p>
        </div>

        {%- comment -%} Social Media Icons {%- endcomment -%}
        {% if section.settings.show_social %}
          <div class="flex items-center gap-4">
            {% if settings.social_facebook_link != blank %}
              <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            {% endif %}

            {% if settings.social_twitter_link != blank %}
              <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                </svg>
              </a>
            {% endif %}

            {% if settings.social_instagram_link != blank %}
              <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            {% endif %}
          </div>
        {% endif %}

        {%- comment -%} Payment Icons {%- endcomment -%}
        {% if section.settings.show_payment_icons %}
          <div class="flex items-center gap-2">
            <span class="text-gray-400 text-sm mr-2">Payment methods</span>
            <div class="flex gap-2">
              <div class="w-12 h-8 bg-white rounded flex items-center justify-center">
                <svg class="h-5" viewBox="0 0 38 24" fill="none">
                  <rect width="38" height="24" rx="3" fill="#1434CB"/>
                  <path d="M23.292 11.892h-8.584l5.422-5.422a.5.5 0 000-.707l-2.828-2.828a.5.5 0 00-.707 0L8.762 10.77a.5.5 0 000 .707l7.833 7.833a.5.5 0 00.707 0l2.828-2.828a.5.5 0 000-.707l-5.422-5.422h8.584a.5.5 0 00.5-.5v-4a.5.5 0 00-.5-.5z" fill="#fff"/>
                </svg>
              </div>
              <div class="w-12 h-8 bg-white rounded flex items-center justify-center">
                <svg class="h-4" viewBox="0 0 38 24">
                  <circle cx="15" cy="12" r="7" fill="#EB001B"/>
                  <circle cx="23" cy="12" r="7" fill="#F79E1B"/>
                  <path d="M19 5.5A7 7 0 0123 12a7 7 0 01-4 6.5A7 7 0 0115 12a7 7 0 014-6.5z" fill="#FF5F00"/>
                </svg>
              </div>
              <div class="w-12 h-8 bg-white rounded flex items-center justify-center">
                <svg class="h-3" viewBox="0 0 38 24">
                  <text x="4" y="16" font-family="Arial" font-size="10" font-weight="bold" fill="#016FD0">AMEX</text>
                </svg>
              </div>
              <div class="w-12 h-8 bg-white rounded flex items-center justify-center">
                <svg class="h-5" viewBox="0 0 38 24">
                  <path d="M35.5 0h-33C1.12 0 0 1.12 0 2.5v19C0 22.88 1.12 24 2.5 24h33c1.38 0 2.5-1.12 2.5-2.5v-19C38 1.12 36.88 0 35.5 0z" fill="#003087"/>
                  <path d="M14 7.5h10v9H14z" fill="#009CDE"/>
                </svg>
              </div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Amari Footer",
  "tag": "footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Skin care products that go beyond the surface, nurturing your skin at its core."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Media Icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link List",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "contact_info",
      "name": "Contact Info",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact Info"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Quick links"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Need Help"
        }
      },
      {
        "type": "contact_info"
      }
    ]
  }
}
{% endschema %}
