<div class="bg-gradient-to-br from-amber-50 to-orange-50 py-16 lg:py-24">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center max-w-7xl mx-auto">
      {%- comment -%} Product Image Section {%- endcomment -%}
      <div class="relative">
        {% if section.settings.badge_image != blank %}
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-32 h-32 lg:w-40 lg:h-40 z-10">
            {{ section.settings.badge_image | image_url: width: 200 | image_tag: class: 'w-full h-full object-contain animate-pulse', loading: 'lazy' }}
          </div>
        {% endif %}

        {% if section.settings.main_image != blank %}
          <div class="rounded-3xl overflow-hidden shadow-2xl">
            {{ section.settings.main_image | image_url: width: 800 | image_tag: class: 'w-full h-auto object-cover', loading: 'lazy' }}
          </div>
        {% endif %}
      </div>

      {%- comment -%} Content Section {%- endcomment -%}
      <div class="space-y-8">
        {% if section.settings.heading != blank %}
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 leading-tight">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <p class="text-gray-600 leading-relaxed">
            {{ section.settings.description }}
          </p>
        {% endif %}

        {%- comment -%} Features Grid {%- endcomment -%}
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-2 xl:grid-cols-3 gap-6">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'feature' %}
                <div class="flex flex-col items-center text-center">
                  {% if block.settings.icon != blank %}
                    <div class="w-16 h-16 mb-3 bg-white rounded-full flex items-center justify-center shadow-md">
                      {{ block.settings.icon | image_url: width: 64 | image_tag: class: 'w-10 h-10 object-contain', loading: 'lazy' }}
                    </div>
                  {% endif %}
                  {% if block.settings.text != blank %}
                    <p class="text-sm font-medium text-gray-700 leading-snug">
                      {{ block.settings.text }}
                    </p>
                  {% endif %}
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Amari Exclusive Products",
  "tag": "section",
  "class": "section-exclusive-products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Power Of Our Exclusive Products"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Experience the transcendence of beauty with the Power of Our Exclusive Products. Elevate your skincare routine with unique formulations crafted to deliver unparalleled results."
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Product Image"
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Badge/Seal Image (appears over main image)"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Feature Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature Text",
          "default": "Perfect for Oily Skin"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Amari Exclusive Products",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "text": "Perfect for Oily & Acne Prone Skin"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Works Efficiently for Skin Nourishment"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Effective in Fighting Infections"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Natural Antiseptic Properties"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Remarkable Cleansing Power"
          }
        }
      ]
    }
  ]
}
{% endschema %}
