<div class="relative bg-[#FFF8F0] overflow-hidden">
  <div class="container mx-auto px-4 py-12 lg:py-20">
    <div class="relative min-h-[600px] lg:min-h-[700px]">
      {%- comment -%} Decorative Oval Images {%- endcomment -%}
      {% if section.settings.oval_image_1 != blank %}
        <div class="absolute top-0 left-0 w-32 h-32 lg:w-48 lg:h-48 rounded-full overflow-hidden">
          {{ section.settings.oval_image_1 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover', loading: 'eager' }}
        </div>
      {% endif %}

      {% if section.settings.oval_image_2 != blank %}
        <div class="absolute left-0 top-1/4 w-24 h-32 lg:w-36 lg:h-48 rounded-full overflow-hidden">
          {{ section.settings.oval_image_2 | image_url: width: 300 | image_tag: class: 'w-full h-full object-cover', loading: 'eager' }}
        </div>
      {% endif %}

      {% if section.settings.oval_image_3 != blank %}
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-80 lg:w-96 lg:h-[500px] rounded-full overflow-hidden border-8 border-white shadow-2xl">
          {{ section.settings.oval_image_3 | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover', loading: 'eager' }}
        </div>
      {% endif %}

      {% if section.settings.oval_image_4 != blank %}
        <div class="absolute right-0 top-1/3 w-28 h-36 lg:w-40 lg:h-52 rounded-full overflow-hidden">
          {{ section.settings.oval_image_4 | image_url: width: 350 | image_tag: class: 'w-full h-full object-cover', loading: 'eager' }}
        </div>
      {% endif %}

      {%- comment -%} Main Content {%- endcomment -%}
      <div class="relative z-10 max-w-lg pt-8 lg:pt-16">
        {% if section.settings.heading != blank %}
          <h2 class="text-4xl lg:text-5xl xl:text-6xl font-bold text-gray-900 leading-tight mb-6">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {%- comment -%} Feature Badges {%- endcomment -%}
        <div class="space-y-3 mb-8">
          {% if section.settings.badge_1_text != blank %}
            <p class="flex items-center text-sm lg:text-base text-gray-700">
              {% if section.settings.badge_1_icon != blank %}
                <span class="text-green-600 mr-2 text-lg">{{ section.settings.badge_1_icon }}</span>
              {% endif %}
              {{ section.settings.badge_1_text }}
            </p>
          {% endif %}

          {% if section.settings.badge_2_text != blank %}
            <p class="flex items-center text-sm lg:text-base text-gray-700">
              {% if section.settings.badge_2_icon != blank %}
                <span class="text-green-600 mr-2 text-lg">{{ section.settings.badge_2_icon }}</span>
              {% endif %}
              {{ section.settings.badge_2_text }}
            </p>
          {% endif %}

          {% if section.settings.badge_3_text != blank %}
            <p class="flex items-center text-sm lg:text-base text-gray-700">
              {% if section.settings.badge_3_icon != blank %}
                <span class="text-green-600 mr-2 text-lg">{{ section.settings.badge_3_icon }}</span>
              {% endif %}
              {{ section.settings.badge_3_text }}
            </p>
          {% endif %}
        </div>

        {%- comment -%} CTA Button {%- endcomment -%}
        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}" class="inline-flex items-center gap-2 bg-amber-800 hover:bg-amber-900 text-white px-6 py-3 rounded-md font-medium transition-colors duration-200">
            {{ section.settings.button_label }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="w-4 h-4">
              <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {% endif %}
      </div>

      {%- comment -%} Product Showcase Cards {%- endcomment -%}
      <div class="absolute right-4 lg:right-12 top-8 lg:top-16 z-20 space-y-4 max-w-[280px]">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'product_card' %}
              {% if block.settings.product != blank %}
                {% assign product = block.settings.product %}
                <a href="{{ product.url }}" class="block bg-white rounded-2xl p-4 shadow-lg hover:shadow-xl transition-shadow duration-200">
                  <div class="flex items-center justify-between mb-3">
                    <div class="flex-1">
                      <h3 class="text-sm font-semibold text-gray-900 line-clamp-2 mb-1">
                        {{ product.title }}
                      </h3>
                      <p class="text-amber-700 font-bold">{{ product.price | money }}</p>
                      {% if product.metafields.reviews.rating.value %}
                        <div class="flex items-center mt-1">
                          <div class="flex text-yellow-400 text-xs">
                            {% for i in (1..5) %}
                              <span>★</span>
                            {% endfor %}
                          </div>
                        </div>
                      {% endif %}
                    </div>
                    {% if product.featured_image %}
                      <div class="w-20 h-20 ml-3 flex-shrink-0">
                        {{ product.featured_image | image_url: width: 150 | image_tag: class: 'w-full h-full object-cover rounded-lg', loading: 'lazy' }}
                      </div>
                    {% endif %}
                  </div>
                </a>
              {% endif %}
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Amari Hero",
  "tag": "section",
  "class": "section-amari-hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Glow Naturally with Every Drop"
    },
    {
      "type": "header",
      "content": "Oval Images"
    },
    {
      "type": "image_picker",
      "id": "oval_image_1",
      "label": "Oval Image 1 (Top Left)"
    },
    {
      "type": "image_picker",
      "id": "oval_image_2",
      "label": "Oval Image 2 (Left)"
    },
    {
      "type": "image_picker",
      "id": "oval_image_3",
      "label": "Oval Image 3 (Center - Main)"
    },
    {
      "type": "image_picker",
      "id": "oval_image_4",
      "label": "Oval Image 4 (Right)"
    },
    {
      "type": "header",
      "content": "Feature Badges"
    },
    {
      "type": "text",
      "id": "badge_1_icon",
      "label": "Badge 1 Icon (emoji or symbol)",
      "default": "✓"
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Badge 1 Text",
      "default": "100% Natural Ingredients"
    },
    {
      "type": "text",
      "id": "badge_2_icon",
      "label": "Badge 2 Icon (emoji or symbol)",
      "default": "✓"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Badge 2 Text",
      "default": "Clinically Proven Hydration"
    },
    {
      "type": "text",
      "id": "badge_3_icon",
      "label": "Badge 3 Icon (emoji or symbol)",
      "default": "✓"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Badge 3 Text",
      "default": "Dermatologist Approved"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Browse Collections"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "limit": 2,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Amari Hero",
      "blocks": [
        {
          "type": "product_card"
        },
        {
          "type": "product_card"
        }
      ]
    }
  ]
}
{% endschema %}
