<style>
  .amari-hero-container {
    background: linear-gradient(135deg, #FFF8F0 0%, #FFF5E6 100%);
    position: relative;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .amari-hero-oval-1 { display: none !important; }
    .amari-hero-oval-2 { display: none !important; }
    .amari-hero-oval-4 { display: none !important; }
  }
</style>

<div class="amari-hero-container">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
    <div class="relative" style="min-height: 700px;">

      {%- comment -%} Background Decorative Ovals {%- endcomment -%}
      {% if section.settings.oval_image_1 != blank %}
        <div class="amari-hero-oval-1 absolute" style="top: 10%; left: 5%; width: 180px; height: 180px; border-radius: 50%; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.1); z-index: 1;">
          {{ section.settings.oval_image_1 | image_url: width: 400 | image_tag: style: 'width: 100%; height: 100%; object-fit: cover;', loading: 'eager' }}
        </div>
      {% endif %}

      {% if section.settings.oval_image_2 != blank %}
        <div class="amari-hero-oval-2 absolute" style="top: 40%; left: 2%; width: 140px; height: 180px; border-radius: 50%; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.1); z-index: 1;">
          {{ section.settings.oval_image_2 | image_url: width: 350 | image_tag: style: 'width: 100%; height: 100%; object-fit: cover;', loading: 'eager' }}
        </div>
      {% endif %}

      {%- comment -%} Central Large Oval - Main Hero Image {%- endcomment -%}
      {% if section.settings.oval_image_3 != blank %}
        <div class="absolute hidden lg:block" style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: 420px; height: 540px; border-radius: 50%; overflow: hidden; border: 12px solid white; box-shadow: 0 30px 80px rgba(0,0,0,0.15); z-index: 2;">
          {{ section.settings.oval_image_3 | image_url: width: 900 | image_tag: style: 'width: 100%; height: 100%; object-fit: cover;', loading: 'eager' }}
        </div>
      {% endif %}

      {% if section.settings.oval_image_4 != blank %}
        <div class="amari-hero-oval-4 absolute hidden lg:block" style="top: 35%; right: 5%; width: 150px; height: 200px; border-radius: 50%; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.1); z-index: 1;">
          {{ section.settings.oval_image_4 | image_url: width: 400 | image_tag: style: 'width: 100%; height: 100%; object-fit: cover;', loading: 'eager' }}
        </div>
      {% endif %}

      {%- comment -%} Main Content - Left Side {%- endcomment -%}
      <div class="relative z-10 pt-8 lg:pt-24" style="max-width: 480px;">
        {% if section.settings.heading != blank %}
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight mb-6" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">
            {{ section.settings.heading }}
          </h1>
        {% endif %}

        {%- comment -%} Feature Badges {%- endcomment -%}
        <div class="space-y-3 mb-8">
          {% if section.settings.badge_1_text != blank %}
            <p class="flex items-center text-base text-gray-700">
              {% if section.settings.badge_1_icon != blank %}
                <span class="text-amber-700 mr-3 text-xl font-bold">{{ section.settings.badge_1_icon }}</span>
              {% endif %}
              <span class="font-medium">{{ section.settings.badge_1_text }}</span>
            </p>
          {% endif %}

          {% if section.settings.badge_2_text != blank %}
            <p class="flex items-center text-base text-gray-700">
              {% if section.settings.badge_2_icon != blank %}
                <span class="text-amber-700 mr-3 text-xl font-bold">{{ section.settings.badge_2_icon }}</span>
              {% endif %}
              <span class="font-medium">{{ section.settings.badge_2_text }}</span>
            </p>
          {% endif %}

          {% if section.settings.badge_3_text != blank %}
            <p class="flex items-center text-base text-gray-700">
              {% if section.settings.badge_3_icon != blank %}
                <span class="text-amber-700 mr-3 text-xl font-bold">{{ section.settings.badge_3_icon }}</span>
              {% endif %}
              <span class="font-medium">{{ section.settings.badge_3_text }}</span>
            </p>
          {% endif %}
        </div>

        {%- comment -%} CTA Button {%- endcomment -%}
        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg font-semibold text-white transition-all duration-300 shadow-lg hover:shadow-xl" style="background-color: #92400E;">
            {{ section.settings.button_label }}
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" class="w-5 h-5">
              <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {% endif %}
      </div>

      {%- comment -%} Product Showcase Cards - Right Side {%- endcomment -%}
      <div class="absolute hidden lg:block" style="right: 50px; top: 80px; z-index: 30; width: 300px;">
        <div class="space-y-4">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'product_card' %}
                {% if block.settings.product != blank %}
                  {% assign product = block.settings.product %}
                  <a href="{{ product.url }}" class="block bg-white rounded-2xl p-5 transition-all duration-300" style="box-shadow: 0 10px 40px rgba(0,0,0,0.12);" onmouseover="this.style.boxShadow='0 15px 50px rgba(0,0,0,0.18)'" onmouseout="this.style.boxShadow='0 10px 40px rgba(0,0,0,0.12)'">
                    <div class="flex items-center gap-4">
                      <div class="flex-1">
                        <h3 class="text-sm font-bold text-gray-900 mb-2 line-clamp-2">
                          {{ product.title }}
                        </h3>
                        <p class="font-bold mb-1" style="color: #92400E; font-size: 16px;">{{ product.price | money }}</p>
                        <div class="flex text-yellow-400 text-xs">
                          <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
                        </div>
                      </div>
                      {% if product.featured_image %}
                        <div class="w-24 h-24 flex-shrink-0 rounded-xl overflow-hidden">
                          {{ product.featured_image | image_url: width: 200 | image_tag: style: 'width: 100%; height: 100%; object-fit: cover;', loading: 'lazy' }}
                        </div>
                      {% endif %}
                    </div>
                  </a>
                {% endif %}
            {% endcase %}
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Amari Hero",
  "tag": "section",
  "class": "section-amari-hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Glow Naturally with Every Drop"
    },
    {
      "type": "header",
      "content": "Oval Images"
    },
    {
      "type": "image_picker",
      "id": "oval_image_1",
      "label": "Oval Image 1 (Top Left)"
    },
    {
      "type": "image_picker",
      "id": "oval_image_2",
      "label": "Oval Image 2 (Left)"
    },
    {
      "type": "image_picker",
      "id": "oval_image_3",
      "label": "Oval Image 3 (Center - Main)"
    },
    {
      "type": "image_picker",
      "id": "oval_image_4",
      "label": "Oval Image 4 (Right)"
    },
    {
      "type": "header",
      "content": "Feature Badges"
    },
    {
      "type": "text",
      "id": "badge_1_icon",
      "label": "Badge 1 Icon (emoji or symbol)",
      "default": "✓"
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Badge 1 Text",
      "default": "100% Natural Ingredients"
    },
    {
      "type": "text",
      "id": "badge_2_icon",
      "label": "Badge 2 Icon (emoji or symbol)",
      "default": "✓"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Badge 2 Text",
      "default": "Clinically Proven Hydration"
    },
    {
      "type": "text",
      "id": "badge_3_icon",
      "label": "Badge 3 Icon (emoji or symbol)",
      "default": "✓"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Badge 3 Text",
      "default": "Dermatologist Approved"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Browse Collections"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "limit": 2,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Amari Hero",
      "blocks": [
        {
          "type": "product_card"
        },
        {
          "type": "product_card"
        }
      ]
    }
  ]
}
{% endschema %}
